# ============================================================
# Backend (FastAPI) — variables d'environnement de PRODUCTION (Railway).
# À définir dans Railway → service backend → Variables.
# NE PAS committer de vraies valeurs : ce fichier ne contient que des exemples.
# ============================================================

# --- Environnement ---
APP_ENV=production            # active gunicorn + garde-fous de config stricts
LOG_LEVEL=INFO
LOG_FORMAT=json

# --- Sécurité (OBLIGATOIRE en production, >= 32 caractères) ---
# Générer :  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=CHANGE-ME-generate-a-48-char-random-secret

# --- PostgreSQL (pgvector REQUIS) ---
# Sur Railway, référencer le plugin Postgres (syntaxe Railway `${{Postgres.*}}`) :
POSTGRES_HOST=${{Postgres.PGHOST}}
POSTGRES_PORT=${{Postgres.PGPORT}}
POSTGRES_DB=${{Postgres.PGDATABASE}}
POSTGRES_USER=${{Postgres.PGUSER}}
POSTGRES_PASSWORD=${{Postgres.PGPASSWORD}}

# --- CORS : autoriser le frontend Vercel ---
BACKEND_CORS_ORIGINS=https://YOUR-VERCEL-APP.vercel.app
# Optionnel : autoriser les déploiements preview Vercel (URLs dynamiques).
BACKEND_CORS_ORIGIN_REGEX=https://.*\.vercel\.app

# --- File d'attente d'ingestion ---
# false = thread d'arrière-plan (déploiement mono-service, sans Redis ni worker).
USE_TASK_QUEUE=false

# --- Migrations au démarrage (bootstrap extensions + alembic upgrade head) ---
RUN_MIGRATIONS=1

# --- IA (Claude) — vide = mode repli déterministe (aucun appel externe) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# --- Workers gunicorn (optionnel) ---
WEB_CONCURRENCY=2

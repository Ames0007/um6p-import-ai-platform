# ============================================================
# Assistant IA Import & Achats UM6P — variables d'environnement
# Copiez ce fichier en `.env` puis renseignez les valeurs.
#
# `docker compose up --build` fonctionne SANS .env (valeurs de dev par défaut).
# Un `.env` est REQUIS en production (docker-compose.prod.yml refuse de démarrer
# avec des secrets par défaut).
# ============================================================

# --- Environnement ---
# development : uvicorn --reload   |   production : gunicorn (workers)
APP_ENV=development
LOG_LEVEL=INFO
LOG_FORMAT=json            # json | text

# --- PostgreSQL (port FIXE 5432, hôte = nom du service docker `postgres`) ---
POSTGRES_USER=um6p
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=um6p_import
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Backend (FastAPI) ---
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:3005
# Générez une clé (>= 32 caractères) :
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-super-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=60

# File d'attente d'ingestion : true en Docker (Redis + worker dédié).
USE_TASK_QUEUE=true
MAX_UPLOAD_SIZE_MB=25

# --- Ingestion documentaire / stockage ---
DOCUMENTS_DIR=./storage/documents
INGESTION_QUEUE_NAME=ingestion
CHUNK_SIZE=1200
CHUNK_OVERLAP=150

# --- OCR (conformité import) — hooks désactivés par défaut ---
OCR_ENABLED=false
OCR_PROVIDER=pdf_text        # pdf_text | tesseract | azure | google | noop
OCR_MIN_CHARS_PER_PAGE=40

# --- Embeddings / recherche sémantique — désactivés par défaut ---
EMBEDDINGS_ENABLED=false
EMBEDDING_DIM=1536

# Intervalle de réconciliation de l'Index de connaissance (secondes).
KI_REFRESH_INTERVAL_SECONDS=20

# --- Claude API (IA) — vide = mode repli déterministe ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# --- Production uniquement ---
# Nombre de workers gunicorn.
WEB_CONCURRENCY=4

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_NAME=Assistant IA Import UM6P

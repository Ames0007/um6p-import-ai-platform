# ============================================================
# Frontend (Next.js) — variables PUBLIQUES (exposées au navigateur).
#   Dév local : copier en `.env.local`.
#   Production : définir dans Vercel (Project → Settings → Environment Variables).
# Ne jamais mettre de secret ici : tout NEXT_PUBLIC_* est visible côté client.
# ============================================================

# URL de base de l'API backend — DOIT inclure le préfixe `/api/v1`.
#   Dév local  : http://localhost:8000/api/v1
#   Production : https://YOUR-RAILWAY-URL/api/v1   (URL publique Railway du backend)
NEXT_PUBLIC_API_URL=https://YOUR-RAILWAY-URL/api/v1

# Nom de l'application (affichage).
NEXT_PUBLIC_APP_NAME=Assistant IA Import UM6P
